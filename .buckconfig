[cells]
# The root cell is named `fixups` so the labels that fixups bake into
# generated BUCK files (e.g. fixups//win:ws2_32.lib) resolve identically
# here and in consumer projects that mount this repo as a `fixups` cell.
fixups = .
prelude = prelude
toolchains = toolchains
none = none

# prelude is vendored on disk (see prelude/) so the windows from_any_dir.py
# os.execl->spawnv fix can be carried until it lands upstream in facebook/buck2.
# Pinned to the prelude bundled by BUCK2_VERSION (tag 2026-06-01).
[cell_aliases]
config = prelude
fbcode = none
fbsource = none
buck = none

[parser]
target_platform_detector_spec = target:fixups//...->prelude//platforms:default

[rust]
default_edition = 2021
remap_src_paths = yes

[project]
ignore = .git, target
